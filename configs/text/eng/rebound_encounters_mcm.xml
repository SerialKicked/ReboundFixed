<string_table>
    <string id="ui_mcm_rebound_encounters_title">
        <text>RE:Bound Encounters: dynamic spawner for RE:Spawn Mutants</text>
    </string>

    <string id="ui_mcm_menu_rebound_encounters">
        <text>RE:Bound Encounters</text>
    </string>

    <string id="ui_mcm_rebound_encounters_spawn_time_delay_min">
        <text>Minimum Time Between Spawns (in-game hours)</text>
    </string>

    <string id="ui_mcm_rebound_encounters_spawn_time_delay_max">
        <text>Maximum Time Between Spawns (in-game hours)</text>
    </string>

    <string id="ui_mcm_rebound_encounters_safe_radius">
        <text>Player Safe Radius</text>
    </string>

    <string id="ui_mcm_rebound_encounters_day_start">
        <text>Day Start Time</text>
    </string>

    <string id="ui_mcm_rebound_encounters_day_end">
        <text>Day End Time</text>
    </string>

    <string id="ui_mcm_rebound_encounters_boss_spawn_probability">
        <text>Success chance for a boss mutant to spawn</text>
    </string>

    <string id="ui_mcm_rebound_encounters_predator_spawn_probability">
        <text>Chance for a spawn to be aggressive</text>
    </string>

    <string id="ui_mcm_rebound_encounters_wipe_mutants_on_level_change">
        <text>Despawn all mutants before switching level</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_ignore_smart_population">
        <text>Ignore Smart population limit when spawning (more spawns)</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_all_maps_spawning">
        <text>No area-specific restrictions for selected weaker mutants</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_boss_is_night_only">
        <text>Boss Mutants Spawn at night only</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_spawn_reserve">
        <text>Ensure slots are consistently reserved on Smarts (lesser spawns)</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_goodwill_penalty">
        <text>Enable goodwill penalty on killing a passive creature from RE:Spawn Pack E</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_sheltered_indicator">
        <text>Enable sheltered status indicator</text>
    </string>
    
    <string id="ui_mcm_rebound_encounters_enable_debug">
        <text>Enable Debug</text>
    </string>

    <string id="ui_mcm_rebound_encounters_delete_mutants_instructions">
        <text>With Debug enabled, pressing the "P" key on your keyboard while in-game will delete all RE:Spawn mutants. Use this if you plan to uninstall some mutants from your game. Save after deleting spawns.</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_random_vanilla_mutants">
        <text>Enable random vanilla mutant spawns after a period of downtime</text>
    </string>

    <string id="ui_mcm_rebound_encounters_random_vanilla_mutants_description">
        <text>Squads of vanilla mutants will spawn near the player after a period of not fighting with a mutant. Chance of spawning increases as downtime increases. Different and stronger mutants will spawn during night time. Adjust the accumulator divisor below. Lesser value = faster spawn chance accumulates</text>
    </string>

    <string id="ui_mcm_rebound_encounters_enable_accumulator_reset_on_npc_attack">
        <text>Reset Spawn accumulator on combat with Stalkers</text>
    </string>

    <string id="ui_mcm_rebound_encounters_accumulator_threshold">
        <text>Accumulator Divisor</text>
    </string>


    

    <string id="ui_mcm_rebound_encounters_toggle_individual_mutant_spawning">
        <text>Toggle each mutant below to control whether it can spawn in your game.</text>
    </string>

