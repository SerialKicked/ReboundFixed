    local texture = sender:character_icon()

	actor:give_game_news(sender_name, msg, texture, 1000, showtime*1000)

end

function check_player_safety()
    actor_in_safe_zone = check_actor_in_safe_zone()
    actor_is_near_lighted_campfire = is_actor_near_lighted_campfire(10)
    is_actor_safe()
    toggle_predator_targeting()
    clear_vanilla_mutant_targets(player_safe)
    check_sheltered_status_changed()
end

function check_sheltered_status_changed()
    local current_sheltered_status = actor_in_safe_zone or actor_is_indoors or actor_is_near_lighted_campfire
    if current_sheltered_status ~= last_sheltered_status then
        last_sheltered_status = current_sheltered_status
        if current_sheltered_status then
            pr("Actor has entered sheltered status, retargeting vanilla mutants.")
            retarget_vanilla_mutants()
        end
    end
end

function calculate_smart_distances()
	local distances = {}
	local actor_pos = db.actor:position()
	
	for _, smart_id in ipairs(available_smart_terrains[level.name()]) do
		local smart = alife_object(smart_id)
		if smart then
		local smart_pos = smart.position
		local distance = actor_pos:distance_to(smart_pos)
		distances[smart_id] = distance
		end
	end
	
	return distances
end

function get_sorted_smart_ids()
	local distances = calculate_smart_distances()
	local sorted_smart_ids = {}

	for smart_id, distance in pairs(distances) do
		if (distance > safe_radius) and (distance < (safe_radius + 100)) then
			table.insert(sorted_smart_ids, {smart_id = smart_id, distance = distance})
		end
	end
		
	table.sort(sorted_smart_ids, function(a, b) return a.distance < b.distance end)

	local result = {}
	for i,entry in ipairs(sorted_smart_ids) do
		result[i] = entry.smart_id
	end

	return result
end

function ease_in_out(t)
    return t * t * (3 - 2 * t)
end

function get_dynamic_weights(player_rank_value)
    local base = {50, 30, 15, 5} -- starting weights
    local max_rank = 8

    local factor = math.min(player_rank_value / max_rank, 1)
    factor = ease_in_out(factor)

    local w1 = base[1] - (base[1] * 0.7 * factor)
    local w2 = base[2] - (base[2] * 0.5 * factor)
    local w3 = base[3] + (base[1] * 0.4 * factor)
    local w4 = base[4] + (base[2] * 0.3 * factor)

    return {math.floor(w1), math.floor(w2), math.floor(w3), math.floor(w4)}
end

function choose_threat_level(max_threat_level, player_rank_value)
    local weights = get_dynamic_weights(player_rank_value)
    local cumulative, total = {}, 0

    for i = 1, max_threat_level do
        total = total + weights[i]
        cumulative[i] = total
    end

    if total == 0 then
        return 1
    end

    local r = math.random(1, total)
    for i = 1, max_threat_level do
        if r <= cumulative[i] then
            return i
        end
    end

    return max_threat_level
end

function spawn_random_mutants_outside_safe_zone()
    local nearest_smarts = get_sorted_smart_ids()
    local current_map_name = tostring(level.name())
    local base_map_threat_level = tonumber(read_ltx_section(plugin_file_name, "map_threat_level", current_map_name)) or 4
    local map_threat_level = base_map_threat_level
    local player_rank_value = get_rank_value(db.actor:character_rank())

    if base_map_threat_level > 1 then
        if player_rank_value <= 2 then
            map_threat_level = math.min(base_map_threat_level, 1)
        elseif player_rank_value <= 4 then
            map_threat_level = math.min(base_map_threat_level, 2)
        end
    end

    -- Pick tier dynamically based on player rank and map cap
    local chosen_threat_level = choose_threat_level(map_threat_level, player_rank_value)

    local simulation_squad_to_spawn = nil
    local simulation_section = is_day() and string.format("simulation_day_mutants_%d", chosen_threat_level) or string.format("simulation_night_mutants_%d", chosen_threat_level)

    local simulation_squads = get_list_from_ltx(plugin_file_name, simulation_section)

    if simulation_squads and #simulation_squads > 0 then
        simulation_squad_to_spawn = simulation_squads[math.random(1, #simulation_squads)]
    else
        pr("No simulation squads found for section: %s", simulation_section)
        return
    end

    if not simulation_squad_to_spawn then
        pr("No suitable squad found for spawning within safe zone.")
        return
    end

    for _, smart_id in ipairs(nearest_smarts) do
        local smart = alife_object(smart_id)
        if smart then
            local is_in_fov = is_smart_in_fov(smart.position)

            if not is_in_fov then
                local squad = SIMBOARD:create_squad(smart, simulation_squad_to_spawn)
                if squad then
                    squad.scripted_target = "actor"
                    squad.rush_to_target = true
                    pr("-- Re:Bound - Spawning Random Vanilla Mutants due to prolonged downtime. Map: %s, Threat Level: %s, Squad: %s", current_map_name, tostring(chosen_threat_level), simulation_squad_to_spawn)
                    game_timer("mark", 5)
                    spawn_accumulator = 0 -- reset after spawn
                    return
                end
            end
        end
    end
end

function is_smart_in_fov(position)
    if not position then return false end

    local ui_position = game.world2ui(position)

    return ui_position and (ui_position.x > 0 and ui_position.x < 1024) and (ui_position.y > 0 and ui_position.y < 768)
end

function is_current_map_exempt()
    local current_map_name = tostring(level.name())
    for _, map_name in ipairs(map_exemptions) do
        if map_name == current_map_name then
            return true
        end
    end
    return false
end

function is_actor_near_lighted_campfire(radius)
	local pos = db.actor:position()
	for id,binder in pairs(bind_campfire.campfires_all) do
		if (binder and binder.campfire and binder.campfire:is_on()) then
			if (pos:distance_to_sqr(binder.object:position()) <= radius) then
				return true
			end
		end 
	end 
	return false
end

function count_squads_in_radius(squad_type, position, radius)
  local count = 0

  for id, _ in pairs(SIMBOARD.squads) do
    local squad = alife_object(id)

    if squad and squad.online then
      local commander = alife_object(squad:commander_id())
      if commander then
        local distance = position:distance_to(commander.position)

        if distance <= radius then
          if squad_type == "all" then
            count = count + 1
          elseif squad_type == "monster" and string.find(squad.player_id, "monster") then
            count = count + 1
          elseif squad_type == "stalker" and not string.find(squad.player_id, "monster") then
            count = count + 1
          end
        end
      end
    end
  end
  pr(" -- RE:Bound - number of squads in radius: %s", count)
  return count
end

