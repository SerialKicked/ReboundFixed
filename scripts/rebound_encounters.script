function spawn_mutant_squad_on_eligible_smart()
    local current_map_name = tostring(level.name())

    -- Check if the current map is exempt
    if is_current_map_exempt() then
        pr("!Current map [%s is exempt from spawning.", current_map_name)
        return
    end

    local base_map_threat_level = tonumber(read_ltx_section(plugin_file_name, "map_threat_level", current_map_name)) or 4
    local map_threat_level = base_map_threat_level
    local player_rank_value = get_rank_value(db.actor:character_rank())

    if base_map_threat_level > 1 then
        if player_rank_value <= 2 then
            map_threat_level = math.min(base_map_threat_level, 1)
        elseif player_rank_value <= 4 then
            map_threat_level = math.min(base_map_threat_level, 2)
        end
    end

    -- Pick tier dynamically based on player rank and map cap
    local chosen_threat_level = choose_threat_level(map_threat_level, player_rank_value)

    local simulation_squad_to_spawn = nil
    local simulation_section = is_day() and string.format("simulation_day_mutants_%d", chosen_threat_level) or string.format("simulation_night_mutants_%d", chosen_threat_level)

    local simulation_squads = get_list_from_ltx(plugin_file_name, simulation_section)

    if simulation_squads and #simulation_squads > 0 then
        -- Reuse the pre-built available_smart_terrains list instead of a full 65K ALife scan.
        -- available_smart_terrains already guarantees population 0 and outside safe radius.
        for _, smart_id in ipairs(available_smart_terrains[current_map_name] or {}) do
            local smart = alife_object(smart_id)

            if smart then
                local smart_name = smart:name() or smart:section_name() or "<empty>"
                local is_in_fov = is_smart_in_fov(smart.position)

                -- Check that the smart terrain is not currently in the player's field of view
                if not is_in_fov then
                    -- Spawn cap: only one squad per call
                    simulation_squad_to_spawn = simulation_squads[math.random(1, #simulation_squads)]
                    local squad = SIMBOARD:create_squad(smart, simulation_squad_to_spawn)
                    if squad then
                        pr("-- Re:Bound - Spawning extra vanilla squad [%s] on smart [%s] (ID: %s)", simulation_squad_to_spawn, smart_name, smart_id)
                        return
                    else
                        pr("! Re:Bound - Failed to spawn squad [%s] on smart [%s] (ID: %s)", simulation_squad_to_spawn, smart_name, smart_id)
                    end
                else
                    pr("! Re:Bound - Smart [%s] (ID: %s) is not eligible for spawning (is in fov: %s)", smart_name, smart_id, tostring(is_in_fov))
                end
            end
        end
    else
        pr("No simulation squads found for section: %s", simulation_section)
    end
end

-- functions for dev purposes only
function on_key_press(key)
    if key == DIK_keys["DIK_U"] and enable_debug then
        get_spawnable_squads_report()
        news_manager.send_tip(db.actor, string.format("-- RE:Bound Encounters - Open console for Spawnable Squads Report"), nil,nil, 3000)
    end
    if key == DIK_keys["DIK_I"] and enable_debug then
        get_active_spawns_report()
        news_manager.send_tip(db.actor, string.format("-- RE:Bound Encounters - Open console for Active Spawns Report"), nil,nil, 3000)
    end

    if key == DIK_keys["DIK_O"] and enable_debug then
        print_passive_fauna_data()
        news_manager.send_tip(db.actor, string.format("-- RE:Bound Encounters - Open console for Passive Fauna Report"), nil,nil, 3000)
    end

    if key == DIK_keys["DIK_P"] and enable_debug then
        delete_mutants()
        get_current_game_values()
        news_manager.send_tip(db.actor, string.format("All active spawns deleted. Saving your game now will make it free from all RE:Spawn mutants. ACTIVE SPAWNS: %d", #active_spawns), nil,nil, 3000)
    end

end

function remove_safe_zone_indicator()
    actor_status.add_indicator("SafeZone", nil)
    pr("-- RE:Bound Encounters: SafeZone indicator removed.")
end

function actor_on_sleep(hours)
    game_timer("mark", 5)
    spawn_accumulator = 0
    if hours > 3 then
        if count_non_respawn_squads() == 0 then
            spawn_mutant_squad_on_eligible_smart()
        else
            pr("RE:Bound - Existing non-respawn spawns detected. Skipping spawn attempt.")
        end
        retarget_vanilla_mutants()
    end
end

function actor_on_footstep()
    passive_spook_distance = 15
    if IsMoveState('mcSprint') then
        passive_spook_distance = 30
    elseif IsMoveState('mcCrouch') then
        passive_spook_distance = 10
        if IsMoveState('mcAccel') then
            passive_spook_distance = 5
        end
    end
end

function on_game_start()
    cooldown_timer("initialize")
    RegisterScriptCallback("actor_on_update", actor_on_update)
    RegisterScriptCallback("monster_on_loot_init", monster_on_loot_init)
    RegisterScriptCallback("monster_on_death_callback", monster_on_death_callback)
    RegisterScriptCallback("server_entity_on_unregister", server_entity_on_unregister)
    RegisterScriptCallback("actor_on_first_update", actor_on_first_update)
    RegisterScriptCallback("save_state", save_state)
    RegisterScriptCallback("load_state", load_state)
    RegisterScriptCallback("on_before_level_changing", on_before_level_changing)
    RegisterScriptCallback("on_option_change", fetch_values)
    RegisterScriptCallback("GUI_on_hide", actor_sleeping)
    RegisterScriptCallback("GUI_on_show", actor_sleeping)
    RegisterScriptCallback("actor_on_sleep", actor_on_sleep)
    RegisterScriptCallback("monster_on_hit_callback", monster_on_hit_callback)
    RegisterScriptCallback("npc_on_hit_callback", npc_on_hit_callback)
    RegisterScriptCallback("on_key_press", on_key_press)
    RegisterScriptCallback("anomaly_on_before_activate", anomaly_on_before_activate)
    RegisterScriptCallback("on_enemy_eval", on_enemy_eval)
    RegisterScriptCallback("on_enemy_eval", force_rush_to_target)
    RegisterScriptCallback("actor_on_footstep", actor_on_footstep)
end