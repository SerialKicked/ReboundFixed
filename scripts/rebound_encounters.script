local spawn_reserve = 1
local enable_goodwill_penalty = true
local boss_spawn_probability = 30
local boss_spawn_attempted = 0
local predator_spawn_probability = 40
local wipe_mutants_on_level_change = true
local enable_debug = false
local max_active_spawns = 0
local smart_terrain_exemptions = {}
local enable_random_vanilla_mutants = true -- toggle option to spawn random vanilla mutants on smart terrains
