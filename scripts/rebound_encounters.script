function get_rank_description(player_rank)
    local ranks = {
        {max_points = 1499, description = "novice"},
        {max_points = 2499, description = "trainee"},
        {max_points = 5499, description = "experienced"},
        {max_points = 9999, description = "professional"},
        {max_points = 14999, description = "veteran"},
        {max_points = 19999, description = "expert"},
        {max_points = 29999, description = "master"},
        {max_points = math.huge, description = "legend"}
    }

    for _, rank in ipairs(ranks) do
        if player_rank <= rank.max_points then
            return rank.description
        end
    end

    return "unknown rank"
end

function get_rank_value(player_rank)
    local ranks = {
        {max_points = 1499, value = 1},   -- "novice"
        {max_points = 2499, value = 2},   -- "trainee"
        {max_points = 5499, value = 3},   -- "experienced"
        {max_points = 9999, value = 4},   -- "professional"
        {max_points = 14999, value = 5},  -- "veteran"
        {max_points = 19999, value = 6},  -- "expert"
        {max_points = 29999, value = 7},  -- "master"
        {max_points = math.huge, value = 8} -- "legend"
    }

    for _, rank in ipairs(ranks) do
        if player_rank <= rank.max_points then
            return rank.value
        end
    end

    return 0
end

function get_phrase_keys(phrase_root)
    local phrase_keys = {}
    local index = 1
    local phrase_key, translated_phrase

    while true do
        phrase_key = string.format("%s_%d", phrase_root, index)
        translated_phrase = game.translate_string(phrase_key)
        if translated_phrase == phrase_key then
            break
        end
        table.insert(phrase_keys, phrase_key)
        index = index + 1
    end
    return phrase_keys
end

function shuffle_table(tbl)
    for i = #tbl, 2, -1 do
        local j = math.random(1, i)
        tbl[i], tbl[j] = tbl[j], tbl[i]
    end
end

function shuffle_smart_ids()
    for _, smart_ids in pairs(available_smart_terrains) do
        shuffle_table(smart_ids)
    end
end

function calculate_opposite_position(position1, position2)
  local direction = vector():sub(position1, position2):normalize()
  local opposite_direction = direction:invert()
  local target_position = vector():add(position2, vector():mul(opposite_direction, 30))
  return target_position
end

-- Remove current action, queue, & script control
function rest(obj)
    if obj:action() then obj:reset_action_queue() end
    if obj:get_script() and obj:get_script_name() == "run_to_e" then obj:script(false, "run_to_e") end
end

-- Movement action
function run_to(obj, pos)
    rest(obj)
    -- Only try to claim if not already under script control
    local state = "run_to_e"
    if not obj:get_script() and obj:get_script_name() ~= state then
        obj:script(true, state)
    end

    local dist_to_target = obj:position():distance_to(pos)
    local move_type = dist_to_target > 10 and move.run_fwd or move.walk_fwd

    -- Queue the move action
    action(obj, move(move_type, pos, 1, move.default), cond(cond.time_end, 500))

    -- Schedule release
    local release_time = time_global() + 500
    obj:set_fastcall(function(self)
        if release_time < time_global() and self:get_script() and self:get_script_name() == "run_to_e" then
            rest(self)
            return true
        end
        return false
    end, obj)
end

function on_enemy_eval(npc, enemy, flags)
    local function matches_section(section)
        for _, value in ipairs(passive_fauna) do
            for _, npc_name in ipairs(value.npcs) do
                if section == npc_name then
                    return true
                end
            end
        end
        return false
    end
    

    local npc_id = npc and npc:id()
    local enemy_id = enemy and enemy:id()

    if not npc_id or not enemy_id then
        return
    end

    local agro_reaction_window = 30
    local was_attacked, timeSinceAttack = is_npc_attacked(npc, agro_reaction_window)

    if (matches_section(npc:section()) or matches_section(enemy:section())) then
        if was_attacked then
            if timeSinceAttack < agro_reaction_window then
                flags.override = false  -- Allow attack
                flags.ret_value = true
            else
                flags.override = true  -- Prevent attack
                flags.ret_value = false
                remove_attacked_npc_id(npc) -- Remove entry from attacked list
            end
        else
            local dist = npc:position():distance_to(enemy:position())
            if dist <= 5 and IsMonster(npc) and IsStalker(enemy) and check_ltx_contains_value(plugin_file_name, "passive_aggressive_fauna", npc:section()) then
                if not cooldown_timer("check", "attacked") then
                    add_attacked_npc_id(npc)
                    cooldown_timer("mark", "attacked", 3)
                end
            elseif dist <= passive_spook_distance and IsMonster(npc) and IsStalker(enemy) then
                local target_position = calculate_opposite_position(enemy:position(), npc:position())
                run_to(npc, target_position)
            end

            flags.override = true  -- Prevent first attack
            flags.ret_value = false
        end
    else
        return
    end
end

function force_rush_to_target(npc, enemy, flags)
    local function matches_section(section)
        for _, value in ipairs(special_spawns) do
            if section == value then
                return true
            end
        end
        return false
    end

    local function is_predator(npc)
        if active_spawns then
            for _, spawn in ipairs(active_spawns) do
                if spawn.mutant_id == npc:id() and spawn.is_predator_mutant then
                    return true
                end
            end
        end
        return false
    end

    if special_event_started() then
        if is_safe_zone == false then
            if matches_section(npc:section())  and (enemy:id() ~= db.actor:id()) then
                local far_from_actor = (npc:position():distance_to(db.actor:position()) > 15)
                if far_from_actor then
                    flags.override = true  -- Prevent attack
                    flags.ret_value = false
                end
            end
        end
    end
    if player_safe == false then
      if is_predator(npc) and (enemy:id() ~= db.actor:id()) then
        local far_from_actor = (npc:position():distance_to(db.actor:position()) > 20)
        if far_from_actor then
            flags.override = true
            flags.ret_value = false
        end
      end
    end
end

function add_safe_zone_indicator()
    actor_status.add_indicator("SafeZone", {
        index = 14,
        typ = "state",
        functor = {"rebound_encounters", "get_safe_zone_status", true},
        icon = "ui\\shelter_indicator\\StatusShelter.dds",
        anim_icon = false,
        anim_bk = false,
    })
    pr("-- RE:Bound Encounters: SafeZone indicator activated.")
end

function set_safe_zone_status(status)
    is_safe_zone = status
end

function get_safe_zone_status(visual)
    if visual then
        if is_safe_zone == true then
            return 1
        elseif is_safe_zone == false then
            return 0
        end
    end
end

function get_nearest_smart_from_mutant_commander(squad)
    local distances = {}
    local squad_commander = alife_object(squad:commander_id())
    if not squad_commander then return nil end

    local commander_position = squad_commander.position
    for _, smart_id in ipairs(available_smart_terrains[level.name()]) do
        local smart = alife_object(smart_id)
        if smart then
            local smart_pos = smart.position
            local distance = commander_position:distance_to(smart_pos)
            distances[smart_id] = distance
        end
    end

    local sorted_smart_ids = {}
    local smart_near_actor = get_nearest_smart_from_actor()

    for smart_id, distance in pairs(distances) do
        if (distance < 300) and (smart_near_actor == nil or smart_id ~= smart_near_actor) then
            table.insert(sorted_smart_ids, {smart_id = smart_id, distance = distance})
        end
    end

    table.sort(sorted_smart_ids, function(a, b) return a.distance < b.distance end)

    if #sorted_smart_ids > 0 then
        return sorted_smart_ids[1].smart_id
    else
        return nil
    end
end

function get_nearest_smart_from_actor()
	local distances = {}
	local actor_pos = db.actor:position()
	
	for _, smart_id in ipairs(available_smart_terrains[level.name()]) do
		local smart = alife_object(smart_id)
		if smart then
			local smart_pos = smart.position
			local distance = actor_pos:distance_to(smart_pos)
			distances[smart_id] = distance
		end
	end

    local sorted_smart_ids = {}

	for smart_id, distance in pairs(distances) do
		if distance < 200 then 
			table.insert(sorted_smart_ids, {smart_id = smart_id, distance = distance})
		end
	end
		
	table.sort(sorted_smart_ids, function(a, b) return a.distance < b.distance end)

    if #sorted_smart_ids > 0 then
        return sorted_smart_ids[1].smart_id
      else
        return nil
    end
end

function get_all_smart_terrain_ids_current_level()
    local current_level_name = level.name()
    local smart_terrain_ids = {}

    for i = 1, MAX_SMART_ID do
        local smart = alife_object(i)
        if smart and smart:clsid() == clsid.smart_terrain then
            local smart_level_name = get_se_obj_level_name(smart)
            if smart_level_name == current_level_name then
                table.insert(smart_terrain_ids, smart.id)
            end
        end
    end

    shuffle_table(smart_terrain_ids)

    return smart_terrain_ids
end

function print_passive_fauna_data()
    pr("-- RE:Bound: Passive Fauna Data:")
    collect_passive_squad_sections()

    local function print_section(title, data)
        if #data > 0 then
            pr(string.format("* %s:", title))
            for i, item in ipairs(data) do
                pr(string.format("  - %s", item))
            end
        else
            pr(string.format("* %s: (Empty)", title))
        end
    end

    print_section("Passives Available", passives_available)

    local fauna_data = {}
    for i, fauna in ipairs(passive_fauna) do
        local npcs_list = #fauna.npcs > 0 and table.concat(fauna.npcs, ", ") or "(Empty)"
        table.insert(fauna_data, npcs_list)
    end
    print_section("Passive Fauna (Config)", fauna_data)

    local active_squad_data = {}
    for i, squad in ipairs(active_passive_squad) do
        local npc = alife_object(squad.npc_id)
        if npc then
            local npc_name = npc and npc:name() or "Unknown NPC"
            local distance = npc and npc.position and db.actor:position():distance_to(npc.position) or "N/A"
            table.insert(active_squad_data, string.format("npc_id=%d, name=%s, distance=%.2f", squad.npc_id, npc_name, distance))
        end
    end
    print_section("Active Passive Squad", active_squad_data)

    pr("----------------------------------")
end

function spawn_passive_squads_near_actor()
    local smart_terrain_ids = get_all_smart_terrain_ids_current_level()
    collect_passive_squad_sections()
    local spawn_threshold = 3

    if active_passive_squad and (#active_passive_squad < spawn_threshold) then
        local actor_pos = db.actor:position()
        local nearest_smart_id = nil
        local nearest_distance = math.huge

        for _, smart_id in ipairs(smart_terrain_ids) do
            local smart = alife_object(smart_id)
            if smart then
                local distance = actor_pos:distance_to(smart.position)
                if distance >= 60 and distance <= 300 and distance < nearest_distance then
                    nearest_smart_id = smart_id
                    nearest_distance = distance
                end
            end
        end

        if nearest_smart_id and #passives_to_spawn > 0 then
            local random_squad = passives_to_spawn[math.random(1, #passives_to_spawn)].sec
            local squad = SIMBOARD:create_squad(alife_object(nearest_smart_id), random_squad)
            if squad then
                for member in squad:squad_members() do
                    table.insert(active_passive_squad, {
                        squad_id = squad.id,
                        npc_id = member.id
                    })
                end
                pr("-- Re:Bound - Spawned passive squad [%s] at smart terrain ID [%s]", random_squad, nearest_smart_id)
            else
                pr("! Re:Bound - Failed to spawn squad at smart terrain ID [%s]", nearest_smart_id)
            end
        else
            pr("! Re:Bound - No suitable smart terrain found for spawning or no squads available.")
        end
    else
        pr("! Re:Bound - Spawn threshold reached. No more passive squads will be spawned.")
    end
end

function FindWitness(victim, who, same_as_victim, same_as_who, not_in_combat, can_see)
    local comm = victim and character_community(victim)
    local comm_sender
    local comm_who = who and character_community(who)
    local who_id = who and who:id()
    local t = {}
    can_see = can_see or nil
  
    for i = 1, #db.OnlineStalkers do
      if (who_id == nil) or (db.OnlineStalkers[i] ~= who_id) then
        local st = db.storage[db.OnlineStalkers[i]]
        local npc = st and st.object
        local faction = nil
        if npc and npc:character_community() then 
            faction = npc:character_community()
        end
        if (npc and IsStalker(npc) and npc:alive() and (faction ~= "zombied") and not get_object_story_id(db.OnlineStalkers[i])) then
          if (not_in_combat == nil) or (not_in_combat and not npc:best_enemy()) or (not_in_combat ~= true) then
            comm_sender = npc:character_community()
            if (same_as_victim == nil) or (same_as_victim and comm_sender == comm) or (same_as_victim == false and comm_sender ~= comm) then
                if (same_as_who == nil) or (same_as_who and comm_sender == comm_who) or (same_as_who == false and comm_sender ~= comm_who) then
                    if (can_see == nil) or (can_see and npc:see(who)) or (can_see == false) then
                        t[#t + 1] = npc
                    end
                end
            end
          end
        end
      end
    end
  
    if #t == 0 then
      return nil
    end
    return t[math.random(#t)]
end

function FindFriendlyWitness(victim, who, same_as_victim, same_as_who, not_in_combat, can_see)
    local comm = victim and character_community(victim)
    local comm_sender
    local comm_who = who and character_community(who)
    local who_id = who and who:id()
    local t = {}
    can_see = can_see or nil

    for i = 1, #db.OnlineStalkers do
        if (who_id == nil) or (db.OnlineStalkers[i] ~= who_id) then
            local st = db.storage[db.OnlineStalkers[i]]
            local npc = st and st.object
            local faction = nil
            if npc and npc:character_community() then 
                faction = npc:character_community()
            end
            if (npc and IsStalker(npc) and npc:alive() and (faction ~= "zombied") and not get_object_story_id(db.OnlineStalkers[i])) then
                if (not_in_combat == nil) or (not_in_combat and not npc:best_enemy()) or (not_in_combat ~= true) then
                    comm_sender = npc:character_community()
                    if (same_as_victim == nil) or (same_as_victim and comm_sender == comm) or (same_as_victim == false and comm_sender ~= comm) then
                        if (same_as_who == nil) or (same_as_who and comm_sender == comm_who) or (same_as_who == false and comm_sender ~= comm_who) then
                            if not game_relations.is_factions_enemies(character_community(db.actor), comm_sender) then
                                if (can_see == nil) or (can_see and npc:see(who)) or (can_see == false) then
                                    t[#t + 1] = npc
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    if #t == 0 then
        return nil
    end
    return t[math.random(#t)]
end

function FindRandomStalker()
    local t = {}

    for i = 1, #db.OnlineStalkers do
        local st = db.storage[db.OnlineStalkers[i]]
        local npc = st and st.object
        local faction = nil
        if npc and npc:character_community() then 
            faction = npc:character_community()
        end
        if (npc and IsStalker(npc) and npc:alive() and (faction ~= "zombied") and not get_object_story_id(db.OnlineStalkers[i]) and not npc:best_enemy()) then
            t[#t + 1] = npc
        end
    end

    if #t == 0 then
        return nil
    end
    return t[math.random(#t)]
end

